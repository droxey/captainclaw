(version 1)

;; ===========================================================================
;; Agent Sandbox Profile — droxey
;; Machine-local, deny-by-default policy modeled on Agent Safehouse.
;; Static rules live here; workdir grants are appended at launch by the
;; companion wrapper script (run-sandboxed.sh).
;;
;; Assembly order mirrors Safehouse profile numbering:
;;   00-base → 10-system-runtime → 20-network → 30-toolchains → 40-shared
;;   → 50-integrations-core → 55-integrations-optional → 60-agents → 70-custom
;;
;; Generated: 2026-03-16
;; Reference: https://github.com/eugene1g/agent-safehouse
;; ===========================================================================


;; ---------------------------------------------------------------------------
;; 00 · Base Profile
;; HOME_DIR, helper macros, deny-by-default.
;; ---------------------------------------------------------------------------

(define HOME_DIR "/Users/droxey")

(define (home-subpath rel) (subpath (string-append HOME_DIR rel)))
(define (home-literal rel) (literal (string-append HOME_DIR rel)))
(define (home-prefix  rel) (prefix  (string-append HOME_DIR rel)))

(deny default)


;; ---------------------------------------------------------------------------
;; 10 · System Runtime
;; Process execution, tmp/dev access, system binaries, and baseline mach
;; services needed by any local agent workflow.
;; ---------------------------------------------------------------------------

;; System binaries and read-only framework paths.
(allow file-read*
    (subpath "/usr")                                                  ;; Core system binaries and libraries.
    (subpath "/bin")                                                  ;; POSIX userland binaries.
    (subpath "/sbin")                                                 ;; System utilities.
    (subpath "/opt")                                                  ;; Homebrew (/opt/homebrew on arm64) and package-manager roots.
    (subpath "/System/Library")                                       ;; macOS runtime frameworks and resources.
    (subpath "/System/Volumes/Preboot")                               ;; dyld/framework lookups via Preboot symlinks.
    (subpath "/Library/Apple")                                        ;; Apple private frameworks touched by Node/Bun/JVM.
    (subpath "/Library/Frameworks")                                   ;; Global framework lookup path for language runtimes.
    (subpath "/Library/Fonts")                                        ;; Font reads for headless renderers/PDF tasks.
    (subpath "/Library/Filesystems/NetFSPlugins")                     ;; Path resolution may load NetFS plugins.
    (subpath "/Library/Preferences/Logging")                          ;; macOS logging prefs during process init.
    (literal "/Library/Preferences/.GlobalPreferences.plist")         ;; Locale/time/user defaults.
    (literal "/Library/Preferences/com.apple.networkd.plist")         ;; DNS/network bootstrap.
    (literal "/dev")                                                  ;; /dev directory listing for shell init.
)

;; Metadata-only traversal on system roots for binary/framework discovery.
(allow file-read-metadata
    (subpath "/System")                                               ;; stat/readdir across /System.
    (subpath "/private/var/run")                                      ;; Socket namespace metadata.
)

;; /etc and /var are symlinks into /private/* on macOS.
(allow file-read*
    (literal "/private")                                              ;; Symlink traversal root.
    (literal "/private/var")                                          ;; Symlink traversal for /var.
    (subpath "/private/var/db/timezone")                              ;; Timezone DB for date/time formatting.
    (literal "/private/var/select/sh")                                ;; /bin/sh selector.
    (literal "/private/var/select/developer_dir")                     ;; xcode-select developer dir pointer.
    (literal "/var/select/developer_dir")                             ;; Compatibility alias.
    (literal "/private/var/db/xcode_select_link")                     ;; xcode-select link lookup.
    (literal "/var/db/xcode_select_link")                             ;; Compatibility alias.
    (literal "/private/etc/hosts")                                    ;; Host override file.
    (literal "/private/etc/resolv.conf")                              ;; DNS resolver config.
    (literal "/private/etc/services")                                 ;; Service name-to-port mappings.
    (literal "/private/etc/protocols")                                ;; Protocol metadata for libc.
    (literal "/private/etc/shells")                                   ;; Valid shell list.
    (subpath "/private/etc/ssl")                                      ;; TLS CA bundles/certs.
    (literal "/private/etc/localtime")                                ;; Localtime symlink.
    (literal "/etc")                                                  ;; Compatibility symlink root.
    (literal "/var")                                                  ;; Compatibility symlink root.
)

;; Metadata traversal for common XDG/home probe paths.
(allow file-read-metadata
    (literal "/home")                                                 ;; Probed by some runtimes.
    (literal "/private/etc")                                          ;; /etc path resolution.
    (subpath "/dev")                                                  ;; stat on /dev entries.
    (home-literal "/.config")                                         ;; XDG config root.
    (home-literal "/.cache")                                          ;; XDG cache root.
    (home-literal "/.local")                                          ;; XDG data root.
    (home-literal "/.local/share")                                    ;; XDG data share dir.
)

;; User preference reads needed by agents/CLIs at startup.
(allow file-read*
    (home-prefix "/Library/Preferences/.GlobalPreferences")           ;; User locale/defaults plist variants.
    (home-prefix "/Library/Preferences/com.apple.GlobalPreferences")  ;; Apple namespaced variant.
    (home-subpath "/Library/Preferences/ByHost")                      ;; Per-host preferences.
    (home-literal "/.CFUserTextEncoding")                             ;; User text encoding prefs.
    (home-literal "/.config")                                         ;; XDG config root directory listing.
    (home-literal "/.cache")                                          ;; XDG cache root directory listing.
    (home-literal "/.local/bin")                                      ;; PATH probing for user-installed helpers.
)

;; Process primitives — agent workflows frequently chain subprocesses.
(allow process-exec)                                                  ;; Execute toolchain binaries, shells, repo tools.
(allow process-fork)                                                  ;; Normal child-process trees.
(allow sysctl-read)                                                   ;; Runtime/process introspection.
(allow process-info* (target same-sandbox))                           ;; Process introspection within sandbox.
(allow signal (target same-sandbox))                                  ;; Signalling child processes.
(allow mach-priv-task-port (target same-sandbox))                     ;; Same-sandbox process controls.
(allow pseudo-tty)                                                    ;; Interactive terminal sessions.

;; Temporary file and socket locations.
(allow file-read* file-write*
    (subpath "/tmp")                                                  ;; Primary temp dir.
    (subpath "/private/tmp")                                          ;; macOS backing path for /tmp.
    (subpath "/var/folders")                                          ;; macOS per-user temp/cache roots.
    (subpath "/private/var/folders")                                  ;; Backing path for /var/folders.
)

;; Defense-in-depth: keep launchd listener sockets opt-in.
(deny file-read* file-write*
    (regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$")
    (regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$")
)

;; Device nodes for shell I/O, PTYs, and descriptor plumbing.
(allow file-read* file-write*
    (subpath "/dev/fd")                                               ;; Process substitution and fd access.
    (literal "/dev/stdout")
    (literal "/dev/stderr")
    (literal "/dev/null")
    (literal "/dev/tty")                                              ;; Controlling terminal.
    (literal "/dev/ptmx")                                             ;; PTY multiplexer.
    (literal "/dev/dtracehelper")                                     ;; dyld/runtime startup probes.
    (regex #"^/dev/tty")
    (regex #"^/dev/ttys")
    (regex #"^/dev/pty")
)

;; Read-only entropy and system probe devices.
(allow file-read*
    (literal "/dev/zero")
    (literal "/dev/autofs_nowait")
    (literal "/dev/dtracehelper")
    (literal "/dev/urandom")                                          ;; Non-blocking entropy.
    (literal "/dev/random")                                           ;; Blocking entropy.
)

;; ioctl restricted to terminal devices.
(allow file-ioctl
    (literal "/dev/dtracehelper")
    (literal "/dev/tty")
    (literal "/dev/ptmx")
    (regex #"^/dev/tty")
    (regex #"^/dev/ttys")
    (regex #"^/dev/pty")
)

;; Baseline mach services commonly touched by runtimes.
(allow mach-lookup
    (global-name "com.apple.system.notification_center")
    (global-name "com.apple.system.opendirectoryd.libinfo")
    (global-name "com.apple.logd")
    (global-name "com.apple.FSEvents")
    (global-name "com.apple.SystemConfiguration.configd")
    (global-name "com.apple.SystemConfiguration.DNSConfiguration")
    (global-name "com.apple.trustd.agent")
    (global-name "com.apple.diagnosticd")
    (global-name "com.apple.analyticsd")
    (global-name "com.apple.dnssd.service")
    (global-name "com.apple.CoreServices.coreservicesd")
    (global-name "com.apple.DiskArbitration.diskarbitrationd")
    (global-name "com.apple.analyticsd.messagetracer")
    (global-name "com.apple.system.logger")
    (global-name "com.apple.coreservices.launchservicesd")
)

(allow system-socket)                                                 ;; AF_SYSTEM sockets for kernel event monitoring.

(allow ipc-posix-shm-read-data
    (ipc-posix-name "apple.shm.notification_center")
)


;; ---------------------------------------------------------------------------
;; 20 · Network
;; Full open — blocking exfiltration is NOT a goal for this sandbox.
;; The goal is reliable agent operation: API calls, package installs, dev servers.
;; ---------------------------------------------------------------------------

(allow network*)


;; ---------------------------------------------------------------------------
;; 30 · Toolchains
;; Per-toolchain read/write grants for detected runtimes, caches, and configs.
;; Detected: Apple CLT, Node.js (nvm), Python (pyenv), Bun, Go, Rust (rustup)
;; ---------------------------------------------------------------------------

;; --- 30a · Apple Toolchain Core ---
;; Curated CLT binaries and support data. LLDB kept opt-in.

(allow file-read*
    ;; Ancestor traversal for CLT whitelist.
    (literal "/Library")
    (literal "/Library/Developer")
    (literal "/Library/Developer/CommandLineTools")
    (literal "/Library/Developer/CommandLineTools/usr")
    (literal "/Library/Developer/CommandLineTools/usr/bin")
    (literal "/Library/Developer/CommandLineTools/usr/include")
    (literal "/Library/Developer/CommandLineTools/usr/lib")
    (literal "/Library/Developer/CommandLineTools/usr/libexec")
    (literal "/Library/Developer/CommandLineTools/usr/libexec/git-core")
    (literal "/Library/Developer/CommandLineTools/usr/share")
    (literal "/Library/Developer/CommandLineTools/SDKs")

    ;; Core SCM / build entrypoints invoked through /usr/bin shims.
    (literal "/Library/Developer/CommandLineTools/usr/bin/git")
    (literal "/Library/Developer/CommandLineTools/usr/bin/make")
    (literal "/Library/Developer/CommandLineTools/usr/bin/gnumake")
    (literal "/Library/Developer/CommandLineTools/usr/bin/clang")
    (literal "/Library/Developer/CommandLineTools/usr/bin/gcc")
    (literal "/Library/Developer/CommandLineTools/usr/bin/cpp")
    (literal "/Library/Developer/CommandLineTools/usr/bin/c89")
    (literal "/Library/Developer/CommandLineTools/usr/bin/c99")
    (literal "/Library/Developer/CommandLineTools/usr/bin/ar")
    (literal "/Library/Developer/CommandLineTools/usr/bin/as")
    (literal "/Library/Developer/CommandLineTools/usr/bin/ld")
    (literal "/Library/Developer/CommandLineTools/usr/bin/ld-classic")
    (literal "/Library/Developer/CommandLineTools/usr/bin/libtool")
    (literal "/Library/Developer/CommandLineTools/usr/bin/lipo")
    (literal "/Library/Developer/CommandLineTools/usr/bin/codesign_allocate")
    (literal "/Library/Developer/CommandLineTools/usr/bin/dsymutil")
    (literal "/Library/Developer/CommandLineTools/usr/bin/bitcode_strip")
    (literal "/Library/Developer/CommandLineTools/usr/bin/install_name_tool")
    (literal "/Library/Developer/CommandLineTools/usr/bin/strip")

    ;; Source-generation and project-maintenance tooling.
    (literal "/Library/Developer/CommandLineTools/usr/bin/bison")
    (literal "/Library/Developer/CommandLineTools/usr/bin/byacc")
    (literal "/Library/Developer/CommandLineTools/usr/bin/flex")
    (literal "/Library/Developer/CommandLineTools/usr/bin/flex++")
    (literal "/Library/Developer/CommandLineTools/usr/bin/lex")
    (literal "/Library/Developer/CommandLineTools/usr/bin/yacc")
    (literal "/Library/Developer/CommandLineTools/usr/bin/m4")
    (literal "/Library/Developer/CommandLineTools/usr/bin/gm4")
    (literal "/Library/Developer/CommandLineTools/usr/bin/bm4")
    (literal "/Library/Developer/CommandLineTools/usr/bin/gperf")
    (literal "/Library/Developer/CommandLineTools/usr/bin/ctags")
    (literal "/Library/Developer/CommandLineTools/usr/bin/mig")
    (literal "/Library/Developer/CommandLineTools/usr/bin/rpcgen")
    (literal "/Library/Developer/CommandLineTools/usr/libexec/migcom")
    (literal "/Library/Developer/CommandLineTools/usr/bin/unifdef")
    (literal "/Library/Developer/CommandLineTools/usr/bin/unifdefall")

    ;; Inspection and formatting utilities.
    (literal "/Library/Developer/CommandLineTools/usr/bin/clang-format")
    (literal "/Library/Developer/CommandLineTools/usr/bin/clangd")
    (literal "/Library/Developer/CommandLineTools/usr/bin/strings")
    (literal "/Library/Developer/CommandLineTools/usr/bin/llvm-cov")
    (literal "/Library/Developer/CommandLineTools/usr/bin/llvm-cxxfilt")
    (literal "/Library/Developer/CommandLineTools/usr/bin/llvm-dwarfdump")
    (literal "/Library/Developer/CommandLineTools/usr/bin/llvm-nm")
    (literal "/Library/Developer/CommandLineTools/usr/bin/llvm-objdump")
    (literal "/Library/Developer/CommandLineTools/usr/bin/llvm-otool")
    (literal "/Library/Developer/CommandLineTools/usr/bin/llvm-profdata")
    (literal "/Library/Developer/CommandLineTools/usr/bin/llvm-size")
    (literal "/Library/Developer/CommandLineTools/usr/bin/dyld_info")
    (literal "/Library/Developer/CommandLineTools/usr/bin/cmpdylib")
    (literal "/Library/Developer/CommandLineTools/usr/bin/nm-classic")
    (literal "/Library/Developer/CommandLineTools/usr/bin/otool-classic")
    (literal "/Library/Developer/CommandLineTools/usr/bin/pagestuff")
    (literal "/Library/Developer/CommandLineTools/usr/bin/size-classic")
    (literal "/Library/Developer/CommandLineTools/usr/bin/nmedit")
    (literal "/Library/Developer/CommandLineTools/usr/bin/segedit")
    (literal "/Library/Developer/CommandLineTools/usr/bin/vtool")

    ;; Support files needed by git/clang and related CLT binaries.
    (subpath "/Library/Developer/CommandLineTools/usr/libexec/git-core")
    (subpath "/Library/Developer/CommandLineTools/usr/include")
    (subpath "/Library/Developer/CommandLineTools/usr/lib")
    (subpath "/Library/Developer/CommandLineTools/usr/share")
    (subpath "/Library/Developer/CommandLineTools/SDKs")
)


;; --- 30b · Node.js ---
;; Node v24 via nvm, npm, yarn, corepack caches.

(allow file-read* file-write*
    ;; Node version managers.
    (home-subpath "/.nvm")
    (home-subpath "/.fnm")

    ;; npm
    (home-subpath "/.npm")
    (home-subpath "/.config/npm")
    (home-subpath "/.cache/npm")
    (home-subpath "/.cache/node")
    (home-subpath "/.cache/prisma")
    (home-subpath "/Library/Caches/npm")
    (home-literal "/.npmrc")
    (home-subpath "/.config/configstore")

    ;; node-gyp
    (home-subpath "/.node-gyp")
    (home-subpath "/.cache/node-gyp")

    ;; pnpm
    (home-subpath "/.config/pnpm")
    (home-subpath "/.pnpm-state")
    (home-subpath "/.pnpm-store")
    (home-subpath "/.local/share/pnpm")
    (home-subpath "/.local/state/pnpm")
    (home-subpath "/Library/pnpm")
    (home-subpath "/Library/Caches/pnpm")
    (home-subpath "/Library/Preferences/pnpm")

    ;; yarn (classic + modern)
    (home-subpath "/.yarn")
    (home-literal "/.yarnrc")
    (home-literal "/.yarnrc.yml")
    (home-subpath "/.config/yarn")
    (home-subpath "/.cache/yarn")
    (home-subpath "/Library/Caches/Yarn")

    ;; corepack
    (home-subpath "/.cache/node/corepack")
    (home-subpath "/Library/Caches/node/corepack")

    ;; browser automation / test runners
    (home-subpath "/Library/Caches/ms-playwright")
    (home-subpath "/Library/Caches/Cypress")
    (home-subpath "/.cache/puppeteer")

    ;; Node ecosystem caches
    (home-subpath "/Library/Caches/typescript")
    (home-subpath "/Library/Caches/prisma-nodejs")
    (home-subpath "/Library/Caches/checkpoint-nodejs")
    (home-subpath "/Library/Caches/claude-cli-nodejs")

    ;; Turborepo
    (home-subpath "/.cache/turbo")
    (home-subpath "/Library/Caches/turbo")
    (home-subpath "/Library/Application Support/turborepo")
)


;; --- 30c · Python ---
;; pyenv, pip, uv, poetry, and ecosystem caches.

(allow file-read* file-write*
    (home-literal "/.local/bin/uv")
    (home-literal "/.local/bin/uvx")
    (home-subpath "/.local/share/uv")
    (home-subpath "/.local/state/uv")
    (home-subpath "/.local/pipx")
    (home-subpath "/.cache/uv")
    (home-subpath "/Library/Caches/uv")
    (home-subpath "/.config/uv")
    (home-subpath "/.cache/pip")
    (home-subpath "/.config/pip")
    (home-subpath "/Library/Caches/pip")
    (home-subpath "/.cache/pypoetry")
    (home-subpath "/.config/pypoetry")
    (home-subpath "/.local/share/pypoetry")
    (home-subpath "/Library/Caches/pypoetry")
    (home-subpath "/.cache/pdm")
    (home-subpath "/.config/pdm")
    (home-subpath "/.local/share/pdm")
    (home-subpath "/.cache/pre-commit")
    (home-subpath "/.cache/mypy")
    (home-subpath "/.cache/ruff")
    (home-subpath "/.virtualenvs")
    (home-subpath "/.ipython")
    (home-subpath "/.jupyter")
    (home-subpath "/.pyenv")
    (home-literal "/.pypirc")
    (home-literal "/.python_history")
    (home-subpath "/.conda")
    (home-subpath "/miniconda3")
    (home-subpath "/miniforge3")
    (home-literal "/.condarc")
    (home-subpath "/.cache/hatch")
    (home-subpath "/.config/hatch")
    (home-subpath "/.local/share/hatch")
)


;; --- 30d · Bun ---
;; Bun runtime, installer, and cache paths.

(allow file-read* file-write*
    (home-subpath "/.bun")
    (home-subpath "/.cache/bun")
    (home-subpath "/.local/state/bun")
    (home-subpath "/.local/share/bun")
    (home-subpath "/Library/Caches/bun")
    (home-literal "/.bunfig.toml")
    (home-literal "/.config/bunfig.toml")
)


;; --- 30e · Go ---
;; Go toolchain, module cache, and build cache paths.

(allow file-read* file-write*
    (home-subpath "/go")
    (home-subpath "/.cache/go-build")
    (home-subpath "/Library/Caches/go-build")
    (home-subpath "/.config/go")
    (home-subpath "/.cache/golangci-lint")
    (home-subpath "/Library/Caches/golangci-lint")
    (home-subpath "/.config/golangci-lint")
    (home-subpath "/.local/share/go")
    (home-subpath "/.goenv")
    (home-subpath "/.cache/gopls")
)


;; --- 30f · Rust ---
;; Rust toolchain via rustup/cargo, config, cache, and optional sccache.

(allow file-read* file-write*
    (home-subpath "/.cargo")
    (home-subpath "/.config/cargo")
    (home-subpath "/.rustup")
    (home-subpath "/.cache/cargo")
    (home-subpath "/Library/Caches/cargo")
    (home-subpath "/.cache/sccache")
    (home-subpath "/Library/Caches/sccache")
    (home-subpath "/Library/Application Support/Mozilla.sccache")
)


;; ---------------------------------------------------------------------------
;; 40 · Shared Agent Context
;; Shared permissions for skills, agents, and guidance files.
;; ---------------------------------------------------------------------------

(allow file-read* file-write*
    (home-subpath "/.skills")                                         ;; Shared skill instructions/scripts.
    (home-subpath "/.agents")                                         ;; Agent config/skills directory.
    (home-literal "/AGENTS.md")                                       ;; Shared agent policy/instructions.
)

(allow file-read*
    (home-subpath "/.claude/agents")                                  ;; Cross-agent shared Claude agents dir.
    (home-subpath "/.claude/skills")                                  ;; Cross-agent shared Claude skills dir.
    (home-literal "/CLAUDE.md")                                       ;; User guidance file.
)


;; ---------------------------------------------------------------------------
;; 50 · Integrations Core
;; Always-on integrations: Git, container deny, SSH agent deny,
;; Launch Services, SCM CLIs, and worktree support.
;; ---------------------------------------------------------------------------

;; --- 50a · Git ---
;; Git client configuration and XDG config directory access.

(allow file-read*
    (home-prefix "/.gitconfig")                                       ;; User gitconfig and variants (.gitconfig.local, etc.).
    (home-prefix "/.gitignore")                                       ;; Global gitignore variants (.gitignore, .gitignore_global).
    (home-subpath "/.config/git")                                     ;; XDG-style git config directory.
    (home-literal "/.gitattributes")                                  ;; Global gitattributes.
    (home-literal "/.ssh")                                            ;; Directory traversal for SSH metadata.
    (home-literal "/.ssh/config")                                     ;; SSH host aliases for git remotes.
    (home-literal "/.ssh/known_hosts")                                ;; Host key verification cache.
)


;; --- 50b · Container Runtime Default Deny ---
;; Docker/Podman sockets denied — Docker not installed.

(deny file-read* file-write*
    (literal "/var/run/docker.sock")
    (literal "/private/var/run/docker.sock")
    (literal "/var/run/podman/podman.sock")
    (literal "/private/var/run/podman/podman.sock")
    (home-literal "/.docker/run/docker.sock")
    (home-literal "/.rd/docker.sock")
    (home-literal "/.orbstack/run/docker.sock")
    (regex (string-append "^" HOME_DIR "/\\.colima/docker\\.sock$"))
    (regex (string-append "^" HOME_DIR "/\\.colima/[^/]+/docker\\.sock$"))
    (regex (string-append "^" HOME_DIR "/\\.local/share/containers/podman/machine/podman\\.sock$"))
    (regex (string-append "^" HOME_DIR "/\\.local/share/containers/podman/machine/[^/]+/podman\\.sock$"))
    (regex (string-append "^" HOME_DIR "/\\.config/containers/podman/machine/podman\\.sock$"))
    (regex (string-append "^" HOME_DIR "/\\.config/containers/podman/machine/[^/]+/podman\\.sock$"))
)

(deny network-outbound
    (remote unix-socket (path-literal "/var/run/docker.sock"))
    (remote unix-socket (path-literal "/private/var/run/docker.sock"))
    (remote unix-socket (path-literal "/var/run/podman/podman.sock"))
    (remote unix-socket (path-literal "/private/var/run/podman/podman.sock"))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.docker/run/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.rd/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.orbstack/run/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.colima/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.colima/[^/]+/docker\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.local/share/containers/podman/machine/podman\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.local/share/containers/podman/machine/[^/]+/podman\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.config/containers/podman/machine/podman\\.sock$")))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.config/containers/podman/machine/[^/]+/podman\\.sock$")))
)


;; --- 50c · SSH Agent Default Deny ---
;; SSH agent credential use is opt-in. Overridden by 55a when SSH is enabled.

(deny network-outbound
    (remote unix-socket (path-regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$"))
    (remote unix-socket (path-regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$"))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.ssh/agent(/.*)?$")))
)


;; --- 50d · Launch Services ---
;; `open` command support for file/URL handlers.

(allow mach-lookup
    (global-name "com.apple.lsd.mapdb")
    (global-name "com.apple.lsd.modifydb")
    (global-name "com.apple.coreservices.quarantine-resolver")
)

(allow file-issue-extension
    (extension-class "com.apple.app-sandbox.read")
    (extension-class "com.apple.app-sandbox.read-write")
)

(allow lsopen)


;; --- 50e · SCM CLIs ---
;; GitHub CLI (gh) and GitLab CLI (glab) config, cache, and state.

(allow file-read* file-write*
    (home-subpath "/.config/gh")
    (home-subpath "/.cache/gh")
    (home-subpath "/.local/share/gh")
    (home-subpath "/.local/state/gh")
    (home-subpath "/.config/glab-cli")
    (home-subpath "/.cache/glab-cli")
    (home-subpath "/.local/share/glab-cli")
    (home-subpath "/.local/state/glab-cli")
)


;; --- 50f · Worktree Common Dir ---
;; Linked worktree shared git common dir — rules generated at launch by
;; run-sandboxed.sh when the workdir resolves to a linked Git worktree.

;; --- 50g · Worktrees ---
;; Read-only sibling worktree paths — rules generated at launch by
;; run-sandboxed.sh via `git worktree list`.


;; ---------------------------------------------------------------------------
;; 55 · Optional Integrations
;; Enabled: SSH, Keychain, Shell Init, Cloud Credentials.
;; ---------------------------------------------------------------------------

;; --- 55a · SSH ---
;; SSH agent sockets, system config, safe config access.
;; Private keys remain denied by default.

;; Defense-in-depth: block private key reads/writes.
(deny file-read* file-write*
    (home-subpath "/.ssh")
)

;; Directory traversal.
(allow file-read-metadata
    (home-literal "/.ssh")
)

;; Non-sensitive SSH metadata needed by git/remote operations.
(allow file-read*
    (home-literal "/.ssh/known_hosts")
    (home-literal "/.ssh/config")
    (home-subpath "/.ssh/config.d")
    (home-literal "/.ssh/allowed_signers")
    (literal "/private/etc/ssh/ssh_config")
    (subpath "/private/etc/ssh/ssh_config.d")
    (literal "/private/etc/ssh/crypto.conf")
    (subpath "/private/etc/ssh/crypto")
)

;; Persist host keys on first connect.
(allow file-write*
    (home-literal "/.ssh/known_hosts")
    (home-literal "/.ssh/known_hosts.old")
)

;; Tahoe-style agent socket directory traversal.
(allow file-read-metadata
    (home-literal "/.ssh/agent")
)

;; SSH agent socket access (overrides 50c default deny).
(allow file-read* file-write*
    (regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$")
    (regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$")
    (home-subpath "/.ssh/agent")
)

(allow network-outbound
    (remote unix-socket (path-regex #"^/private/tmp/com\.apple\.launchd\.[^/]+/Listeners$"))
    (remote unix-socket (path-regex #"^/tmp/com\.apple\.launchd\.[^/]+/Listeners$"))
    (remote unix-socket (path-regex (string-append "^" HOME_DIR "/\\.ssh/agent(/.*)?$")))
)


;; --- 55b · Keychain ---
;; macOS Keychain and Security framework for agent auth/credential storage.

(allow file-read* file-write*
    (home-subpath "/Library/Keychains")
    (home-literal "/Library/Preferences/com.apple.security.plist")
)

(allow file-read*
    (literal "/Library/Preferences/com.apple.security.plist")
    (literal "/Library/Keychains/System.keychain")
    (subpath "/private/var/db/mds")
)

(allow file-read-metadata
    (home-literal "/Library")
    (home-literal "/Library/Keychains")
    (literal "/Library")
    (literal "/Library/Keychains")
)

(allow mach-lookup
    (global-name "com.apple.SecurityServer")
    (global-name "com.apple.security.agent")
    (global-name "com.apple.securityd.xpc")
    (global-name "com.apple.security.authhost")
    (global-name "com.apple.secd")
    (global-name "com.apple.trustd")
)

(allow ipc-posix-shm-read-data ipc-posix-shm-write-create ipc-posix-shm-write-data
    (ipc-posix-name "com.apple.AppleDatabaseChanged")
)


;; --- 55c · Shell Init ---
;; Shell startup file reads for zsh and bash.

(allow file-read*
    ;; Shared shell startup files and PATH defaults.
    (literal "/private/etc/profile")
    (literal "/private/etc/paths")
    (subpath "/private/etc/paths.d")

    ;; Bash startup files.
    (literal "/private/etc/bashrc")

    ;; Zsh startup files and completion cache.
    (literal "/private/etc/zprofile")
    (literal "/private/etc/zshrc")
    (home-literal "/.zshenv")
    (home-literal "/.zprofile")
    (home-literal "/.zshrc")
    (home-literal "/.zcompdump")
    (home-prefix "/.zcompdump")
)


;; --- 55d · Cloud Credentials ---
;; AWS, GCP, and Azure CLI/SDK credential, config, and cache access.

(allow file-read* file-write*
    (home-subpath "/.aws")
    (home-subpath "/.config/gcloud")
    (home-subpath "/.azure")
    (home-subpath "/.azd")
)


;; ---------------------------------------------------------------------------
;; 60 · Agents
;; Per-agent binary, state, config, and MCP integration paths.
;; Detected: Claude Code, Codex, Gemini CLI.
;; ---------------------------------------------------------------------------

;; --- 60a · Claude Code ---

(allow file-read* file-write*
    (home-prefix "/.local/bin/claude")
    (home-subpath "/.cache/claude")
    (home-subpath "/.claude")
    (home-prefix "/.claude.json")
    (home-literal "/.claude.lock")
    (home-subpath "/.config/claude")
    (home-subpath "/.local/state/claude")
    (home-subpath "/.local/share/claude")
    (home-literal "/.mcp.json")
)

(allow file-read*
    (home-prefix "/.claude.json.")
    (home-literal "/Library/Application Support/Claude/claude_desktop_config.json")
    (subpath "/Library/Application Support/ClaudeCode/.claude")
    (literal "/Library/Application Support/ClaudeCode/managed-settings.json")
    (literal "/Library/Application Support/ClaudeCode/managed-mcp.json")
    (literal "/Library/Application Support/ClaudeCode/CLAUDE.md")
)


;; --- 60b · Codex ---

(allow file-read* file-write*
    (home-prefix "/.local/bin/codex")
    (home-subpath "/.codex")
    (home-subpath "/.cache/codex")
)

(allow file-read*
    (home-literal "/Library/Preferences/com.openai.codex.plist")
    (literal "/Library/Preferences/com.openai.codex.plist")
    (literal "/Library/Managed Preferences/com.openai.codex.plist")
    (subpath "/etc/codex")
)


;; --- 60c · Gemini CLI ---

(allow file-read* file-write*
    (home-prefix "/.local/bin/gemini")
    (home-subpath "/.gemini")
    (home-subpath "/.cache/gemini")
)

(allow file-read*
    (subpath "/Library/Application Support/GeminiCli")
)


;; ---------------------------------------------------------------------------
;; 70 · Custom Grants
;; User-specified static directory grants.
;; ---------------------------------------------------------------------------

;; --- 70a · ~/dev/repos (read-write) ---
;; Ancestor traversal, then full RW on all repos.

(allow file-read*
    (home-literal "/dev")
)

(allow file-read* file-write*
    (home-subpath "/dev/repos")
)


;; --- 70b · ~/Downloads (read-only) ---

(allow file-read*
    (home-subpath "/Downloads")
)


;; --- 70c · iCloud Drive (read-only) ---
;; Scoped to com~apple~CloudDocs — other app containers stay hidden.

(allow file-read*
    (home-literal "/Library/Mobile Documents")
    (home-subpath "/Library/Mobile Documents/com~apple~CloudDocs")
)


;; ---------------------------------------------------------------------------
;; 80 · Workdir
;; Appended at launch by run-sandboxed.sh — NOT present in the static profile.
;; The wrapper generates ancestor literals + subpath RW for the resolved workdir,
;; plus read-only grants for sibling worktrees and RW for linked git common dirs.
;; ---------------------------------------------------------------------------
